<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/litertlm_spacing_sm">

    <TextView
        android:id="@+id/messageText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/litertlm_spacing_sm"
        android:maxWidth="@dimen/litertlm_message_max_width"
        android:paddingHorizontal="@dimen/litertlm_spacing_md"
        android:paddingVertical="@dimen/litertlm_spacing_sm"
        android:textSize="@dimen/litertlm_text_normal"
        android:lineSpacingMultiplier="1.2" />

</FrameLayout>
